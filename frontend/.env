# Variables de entorno para desarrollo local.
# Este archivo está en .gitignore — nunca se sube al repo.
# Para producción, configurar las variables directamente en el dashboard de Vercel.

# URL base del backend (el proxy de Vite redirige /api → http://127.0.0.1:8000)
VITE_API_BASE_URL=/api

# URL del webhook de AICoach (opcional — si no se define, el coach usa respuestas locales)
# VITE_AICOACH_WEBHOOK_URL=https://tu-webhook-n8n.com/webhook/...
